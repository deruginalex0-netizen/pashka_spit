      "id": "6f2f03fd-01e3-4b60-a001-111111111103",
      "name": "IF — Validate Order Payload",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        480,
        120
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const store = $getWorkflowStaticData('global');\n\nif (!store.pendingOrders || typeof store.pendingOrders !== 'object') {\n  store.pendingOrders = {};\n}\n\nconst body = $('Webhook — Receive Order').first().json.body || {};\nconst orderId = String(body.order_id || '').trim();\nconst username = String(body.telegram_username || '').trim().replace(/^@/, '').toLowerCase();\nconst photoIds = Array.isArray(body.photo_ids) ? body.photo_ids.map((x) => String(x)).filter(Boolean) : [];\nconst now = Date.now();\n\n// Cleanup orders older than 7 days\nconst ttlMs = 7 * 24 * 60 * 60 * 1000;\nconst cleaned = {};\nfor (const [key, value] of Object.entries(store.pendingOrders)) {\n  if (value && value.created_at && now - value.created_at <= ttlMs) {\n    cleaned[key] = value;\n  }\n}\n\ncleaned[orderId] = {\n  order_id: orderId,\n  telegram_username: username,\n  customer_full_name: body.customer_full_name || '',\n  customer_email: body.customer_email || '',\n  photo_ids: photoIds,\n  github_owner: body.github_owner || 'deruginalex0-netizen',\n  github_repo: body.github_repo || 'pashka_spit',\n  created_at: now\n};\n\nstore.pendingOrders = cleaned;\n\nreturn [{\n  json: {\n    status: 'ok',\n    message: 'Order accepted',\n    order_id: orderId,\n    bot_link: `https://t.me/AAAAAAA_blya_bot?start=${encodeURIComponent(orderId)}`\n  }\n}];"
      },
      "id": "6f2f03fd-01e3-4b60-a001-111111111104",
      "name": "Code — Save Pending Order",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        740,
        120
      ]
    },
