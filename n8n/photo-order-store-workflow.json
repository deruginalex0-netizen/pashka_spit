    },
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "order-consume",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "6f2f03fd-01e3-4b60-a001-111111111108",
      "name": "Webhook — Consume Order",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        620
      ],
      "webhookId": "order-consume"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const store = $getWorkflowStaticData('global');\n\nif (!store.pendingOrders || typeof store.pendingOrders !== 'object') {\n  store.pendingOrders = {};\n}\n\nconst query = $('Webhook — Consume Order').first().json.query || {};\n\nconst secret = String(query.secret || '');\nif (secret !== 'whsec_83a2c18c7719671edb0cd08b2dfba88f8200d8683c76509f') {\n  return [{ json: { status: 'error', code: 'unauthorized', message: 'Unauthorized' } }];\n}\n\nconst requestedOrderId = String(query.order_id || '').trim();\nif (!requestedOrderId) {\n  return [{ json: { status: 'error', code: 'invalid_request', message: 'order_id is required' } }];\n}\n\nconst order = store.pendingOrders[requestedOrderId];\nif (!order) {\n  return [{ json: { status: 'error', code: 'not_found', message: 'Order not found or already delivered' } }];\n}\n\nconst requestUsername = String(query.telegram_username || '').trim().replace(/^@/, '').toLowerCase();\nif (order.telegram_username && requestUsername && order.telegram_username !== requestUsername) {\n  return [{ json: { status: 'error', code: 'username_mismatch', message: 'This order belongs to another Telegram username' } }];\n}\n\nconst nextPending = { ...store.pendingOrders };\ndelete nextPending[requestedOrderId];\nstore.pendingOrders = nextPending;\n\nreturn [{\n  json: {\n    status: 'ok',\n    order\n  }\n}];"
      },
