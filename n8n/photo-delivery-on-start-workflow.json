    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const msg = $json.message || {};\nconst text = String(msg.text || '').trim();\nconst chatId = String(msg.chat?.id || '');\nconst username = String(msg.from?.username || '').trim();\n\nif (!text.startsWith('/start')) {\n  return [{ json: { status: 'ignore', chat_id: chatId, telegram_username: username } }];\n}\n\nconst parts = text.split(/\\s+/);\nconst orderId = parts[1] ? parts[1].trim() : '';\nif (!orderId) {\n  return [{ json: { status: 'missing_order_id', chat_id: chatId, telegram_username: username } }];\n}\n\nif (!username) {\n  return [{ json: { status: 'missing_username', chat_id: chatId, telegram_username: '' } }];\n}\n\nreturn [{\n  json: {\n    status: 'ok',\n    chat_id: chatId,\n    order_id: orderId,\n    telegram_username: username.replace(/^@/, '').toLowerCase()\n  }\n}];"
      },
      "id": "ab381f0d-89b4-4f19-9152-222222222202",
      "name": "Code — Parse Start Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [250, 220]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-start-ok",
              "leftValue": "={{ $json.status }}",
              "rightValue": "ok",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "ab381f0d-89b4-4f19-9152-222222222203",
